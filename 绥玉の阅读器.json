  shelf.appendChild(empty);
} else {
  var grid = D.createElement('div');
  grid.className = 'snr-books-grid';
  S.books.forEach(function (book, i) {
    var prog = S.progress[book.id] || 0;
    var total = book.pageCount || 1;
    var pct = Math.round(prog / total * 100);
    var card = D.createElement('div');
    card.className = 'snr-book-card';

    var del = D.createElement('div');
    del.className = 'snr-book-del';
    del.setAttribute('data-id', book.id);
    del.textContent = '✕';

    var cover = D.createElement('div');
    cover.className = 'snr-book-cover';
    cover.style.background = BOOK_COLORS[i % BOOK_COLORS.length];
    cover.textContent = '📖';

    var name = D.createElement('div');
    name.className = 'snr-book-name';
    name.textContent = book.title;

    var pctEl = D.createElement('div');
    pctEl.className = 'snr-book-pct';
    pctEl.textContent = prog > 0 ? pct + '%' : '未读';

    card.appendChild(del);
    card.appendChild(cover);
    card.appendChild(name);
    card.appendChild(pctEl);

    card.onclick = function (e) {
      if (e.target.closest && e.target.closest('.snr-book-del')) return;
      openBook(book.id);
    };
    del.onclick = function (e) {
      e.stopPropagation();
      if (P.confirm('删除《' + book.title + '》？')) { deleteBook(book.id); render(); }
    };
    grid.appendChild(card);
  });
  shelf.appendChild(grid);
}
root.appendChild(shelf);
```


// ST 小说伴读器 v2.0
// 使用方式：粘贴到 SillyTavern「扩展 → JS-Slash-Runner → 全局脚本」并启用
// 不需要 Tampermonkey

(function () {
‘use strict’;

// ═══════════════════════════════════════════════════════════
//  CORE REFS — 在 JS-Slash-Runner iframe 里，parent 才是 ST 主页面
// ═══════════════════════════════════════════════════════════
var P = window.parent;
var D = P.document;

var ST = function () {
try {
return P.SillyTavern && P.SillyTavern.getContext ? P.SillyTavern.getContext() : null;
} catch (e) { return null; }
};

var ROOT_ID = ‘snr-root’;
var FAB_ID  = ‘snr-fab’;
var CSS_ID  = ‘snr-css’;
var LS_KEY  = ‘st_novel_reader_v1’;
var CHARS_PER_PAGE = 900;

// ─── 去重：移除旧实例再重建，不直接退出 ───────────────────
var _old = D.getElementById(ROOT_ID); if (_old) _old.remove();
var _ofb = D.getElementById(FAB_ID);  if (_ofb) _ofb.remove();
var _ocs = D.getElementById(CSS_ID);  if (_ocs) _ocs.remove();

// ═══════════════════════════════════════════════════════════
//  本地存储（用 parent 的 localStorage）
// ═══════════════════════════════════════════════════════════
var Store = {
load: function () {
try { return JSON.parse(P.localStorage.getItem(LS_KEY) || ‘{}’); }
catch (e) { return {}; }
},
save: function (d) { P.localStorage.setItem(LS_KEY, JSON.stringify(d)); },
get: function (k, z) {
var data = this.load();
return (data[k] !== undefined && data[k] !== null) ? data[k] : z;
},
set: function (k, v) {
var d = this.load(); d[k] = v; this.save(d);
}
};

// ═══════════════════════════════════════════════════════════
//  全局状态
// ═══════════════════════════════════════════════════════════
var S = {
panelOpen:     false,
view:          ‘shelf’,
books:          Store.get(‘books’,    []),
currentBookId:  null,
currentPage:    0,
pages:          [],
charInfo:       null,
charHidden:     Store.get(‘charHidden’, false),
bubbleText:     ‘’,
bubbleLoading:  false,
memories:       Store.get(‘memories’,  {}),
bookmarks:      Store.get(‘bookmarks’, {}),
progress:       Store.get(‘progress’,  {}),
settingsOpen:   false,
thoughtsOpen:   false,
plusOpen:       false,
lpMenuOpen:     false,
touchStartX:    0
};

var root; // 面板元素
var fab;  // 浮动触发按钮

// ═══════════════════════════════════════════════════════════
//  角色信息
// ═══════════════════════════════════════════════════════════
function getCharInfo() {
try {
var ctx = ST(); if (!ctx) return null;
var idx = ctx.characterId; if (idx == null) return null;
var ch = ctx.characters[idx]; if (!ch) return null;
return {
name:        ch.name        || ‘角色’,
avatarUrl:   ch.avatar ? ‘/characters/’ + encodeURIComponent(ch.avatar) : null,
description: ch.description || ‘’,
personality: ch.personality || ‘’
};
} catch (e) { return null; }
}

function refreshChar() {
S.charInfo = getCharInfo();
updateCharArea();
if (S.settingsOpen) openSettings(true);
}

setInterval(function () {
var n = getCharInfo();
var nName = n ? n.name : null, nUrl = n ? n.avatarUrl : null;
var oName = S.charInfo ? S.charInfo.name : null, oUrl = S.charInfo ? S.charInfo.avatarUrl : null;
if (nName !== oName || nUrl !== oUrl) { S.charInfo = n; updateCharArea(); }
}, 2000);

try {
if (typeof eventOn === ‘function’ && typeof tavern_events !== ‘undefined’) {
eventOn(tavern_events.CHARACTER_SELECTED, refreshChar);
}
} catch (e) {}

// ═══════════════════════════════════════════════════════════
//  书籍管理
// ═══════════════════════════════════════════════════════════
function importBook(file) {
return new Promise(function (res, rej) {
var fr = new FileReader();
fr.onload = function (e) {
var content = e.target.result;
var pages   = splitPages(content);
var book    = {
id: Date.now().toString(), title: file.name.replace(/.(txt|md)$/i, ‘’),
content: content, pageCount: pages.length, addedAt: Date.now()
};
S.books.unshift(book);
Store.set(‘books’, S.books);
res(book);
};
fr.onerror = rej;
fr.readAsText(file, ‘utf-8’);
});
}

function deleteBook(id) {
S.books = S.books.filter(function (b) { return b.id !== id; });
[‘books’, ‘memories’, ‘bookmarks’, ‘progress’].forEach(function (k) {
if (k === ‘books’) Store.set(k, S.books);
else { delete S[k][id]; Store.set(k, S[k]); }
});
}

function openBook(id) {
var book = S.books.find(function (b) { return b.id === id; });
if (!book) return;
S.currentBookId = id;
S.pages         = splitPages(book.content);
if (!S.pages.length) S.pages = [’[空白文件]’];
S.currentPage   = S.progress[id] || 0;
S.view          = ‘reader’;
S.bubbleText    = ‘’; S.bubbleLoading = false;
S.plusOpen = false; S.thoughtsOpen = false;
render();
}

function closeBook() {
S.view = ‘shelf’; S.currentBookId = null; S.pages = [];
S.bubbleText = ‘’; S.bubbleLoading = false;
S.plusOpen = false; S.thoughtsOpen = false; S.lpMenuOpen = false;
render();
}

// ═══════════════════════════════════════════════════════════
//  分页
// ═══════════════════════════════════════════════════════════
function splitPages(text) {
if (!text || !text.trim()) return [’[空白文件]’];
var paras = text.split(/\n\s*\n/).map(function (p) { return p.trim(); }).filter(Boolean);
var pages = [], cur = ‘’;
for (var i = 0; i < paras.length; i++) {
var p = paras[i];
if (cur.length + p.length + 2 > CHARS_PER_PAGE && cur) { pages.push(cur.trim()); cur = p; }
else cur += (cur ? ‘\n\n’ : ‘’) + p;
}
if (cur.trim()) pages.push(cur.trim());
return pages.length ? pages : [text];
}

function goToPage(n) {
S.currentPage = Math.max(0, Math.min(n, S.pages.length - 1));
S.progress[S.currentBookId] = S.currentPage;
Store.set(‘progress’, S.progress);
S.bubbleText = ‘’; S.thoughtsOpen = false; S.plusOpen = false;
renderReaderContent(); updatePageNav(); updateTopPageNum(); updateCharArea();
}

// ═══════════════════════════════════════════════════════════
//  书签
// ═══════════════════════════════════════════════════════════
function toggleBookmark() {
var id = S.currentBookId;
if (!S.bookmarks[id]) S.bookmarks[id] = [];
var idx = S.bookmarks[id].indexOf(S.currentPage);
if (idx >= 0) S.bookmarks[id].splice(idx, 1);
else S.bookmarks[id].push(S.currentPage);
Store.set(‘bookmarks’, S.bookmarks);
updateBmBtn();
}

function isBookmarked() {
return (S.bookmarks[S.currentBookId] || []).indexOf(S.currentPage) >= 0;
}

// ═══════════════════════════════════════════════════════════
//  记忆
// ═══════════════════════════════════════════════════════════
function addMemory(bookId, content, type) {
if (!S.memories[bookId]) S.memories[bookId] = [];
S.memories[bookId].push({ id: Date.now().toString(), type: type, content: content, page: S.currentPage, ts: Date.now() });
Store.set(‘memories’, S.memories);
}

// ═══════════════════════════════════════════════════════════
//  AI 调用
// ═══════════════════════════════════════════════════════════
var charName  = function () { return S.charInfo ? (S.charInfo.name || ‘角色’) : ‘角色’; };
var bookTitle = function () { var b = S.books.find(function (b) { return b.id === S.currentBookId; }); return b ? b.title : ‘小说’; };
var curPage   = function () { return S.pages[S.currentPage] || ‘’; };

async function aiCall(userInput, systemExtra, maxHistory) {
if (typeof generateRaw !== ‘function’) return ‘（AI接口不可用，请确保已连接API）’;
var hist = (maxHistory !== undefined && maxHistory !== null) ? maxHistory : ‘all’;
return await generateRaw({
user_input: systemExtra + ‘\n\n’ + userInput,
max_chat_history: hist,
ordered_prompts: [‘char_description’, ‘chat_history’, ‘user_input’]
});
}

async function generateChat(userMsg) {
var novelCtx = ‘【当前阅读：《’ + bookTitle() + ‘》第 ’ + (S.currentPage + 1) + ’ 页】\n’ + curPage().slice(0, 600);
var sys = ‘你正在陪伴用户阅读小说《’ + bookTitle() + ‘》。保持你的角色性格，语气自然真实，像朋友聊天一样，回复简短有温度。’;
try { return await aiCall(novelCtx + ‘\n\n用户：’ + userMsg, sys, 8); }
catch (e) { return ‘（暂时没有回应…）’; }
}

async function generateThoughts() {
var sys = ‘你是’ + charName() + ‘，以下是你此刻真实的内心独白——可能是对这段小说内容的真实感受（未必和你表面说的一致）；可能走神想到了别的事；也可能表里如一、专心在看。一切以符合你的性格为准。50-100字，第一人称内心独白。’;
try { return await aiCall(‘小说《’ + bookTitle() + ‘》第 ’ + (S.currentPage + 1) + ’ 页：\n’ + curPage().slice(0, 800), sys, 0); }
catch (e) { return ‘（心绪不明…）’; }
}

async function generateMemory(content, type) {
var prevMems = S.memories[S.currentBookId] || [];
var prev = prevMems.slice(-2).map(function (m) { return m.content; }).join(’\n—\n’);
var instruction = type === ‘page’
? ‘请对下面这段小说内容生成记忆摘要（80-150字）：\n- 概括核心情节\n- 保留关键细节与转折\n- 若有用户与你讨论的重要内容，原文保留\n- 用”本页记忆：“开头’
: ‘请对下面的小说内容生成记忆摘要（150-250字）：\n- 大部分内容简要概括\n- 当前页及重点剧情详细描述\n- 若有用户与你讨论的重要内容，原文保留\n- 用”进度记忆：“开头\n\n参考已有记忆：\n’ + (prev || ‘（暂无）’);
try { return await aiCall(instruction + ‘\n\n内容：\n’ + content.slice(0, 3000), ‘你是’ + charName() + ‘，正在整理阅读记忆。’, 0); }
catch (e) { return content.slice(0, 200) + ‘…（摘要生成失败）’; }
}

async function sendPageToChar(includeAll) {
closeLPMenu();
S.bubbleText = ‘’; S.bubbleLoading = true;
updateCharArea();
var content = includeAll ? S.pages.slice(0, S.currentPage + 1).join(’\n\n—\n\n’) : curPage();
var prompt = includeAll
? ‘我把《’ + bookTitle() + ‘》从头到第 ’ + (S.currentPage + 1) + ’ 页都发给你看了，你有什么感想？’
: ‘我把《’ + bookTitle() + ‘》第 ’ + (S.currentPage + 1) + ’ 页发给你，你怎么看这段？’;
try {
var reaction = await generateChat(prompt + ‘\n\n[内容节选]\n’ + content.slice(0, 1200));
S.bubbleLoading = false; S.bubbleText = reaction; updateCharArea();
var mem = await generateMemory(content, includeAll ? ‘all’ : ‘page’);
addMemory(S.currentBookId, mem, includeAll ? ‘cumulative’ : ‘page’);
toast(‘记忆已保存 ✓’);
} catch (e) {
S.bubbleLoading = false; S.bubbleText = ‘（发送失败，请重试）’; updateCharArea();
}
}


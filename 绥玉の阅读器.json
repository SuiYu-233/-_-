function finishInit() {
S.charInfo = getCharInfo();
S.books.forEach(function (b) {
if (!b.pageCount && b.content) b.pageCount = splitPages(b.content).length;
});
render();
console.log(’[ST小说伴读器 v2.0] 已启动 ✓ — 点击右下角📚按钮打开面板’);

```
// ── 守护：被 ST 框架移除时自动重新挂载 ─────────────────
var reattachFab  = function () { if (!D.body.contains(fab))  D.body.appendChild(fab); };
var reattachRoot = function () { if (!D.body.contains(root)) D.body.appendChild(root); };
var guard = new MutationObserver(function () { reattachFab(); reattachRoot(); });
guard.observe(D.body, { childList: true });

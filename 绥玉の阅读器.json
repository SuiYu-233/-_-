}

function closePanel() {
S.panelOpen = false;
root.classList.remove(‘snr-open’);
fab.textContent = ‘📚’;
fab.title = ‘打开伴读器’;
// 同时关掉长按菜单和设置
closeLPMenu();
closeSettings();
}

function togglePanel() {
if (S.panelOpen) closePanel(); else openPanel();
}

// ═══════════════════════════════════════════════════════════
//  工具函数
// ═══════════════════════════════════════════════════════════
var esc = function (s) {
return String(s || ‘’).replace(/&/g, ‘&’).replace(/</g, ‘<’).replace(/>/g, ‘>’).replace(/”/g, ‘"’);
};
var fmtT = function (ts) {
var d = new Date(ts);
return (d.getMonth() + 1) + ‘/’ + d.getDate() + ’ ’ + d.getHours() + ‘:’ + String(d.getMinutes()).padStart(2, ‘0’);
};
var BOOK_COLORS = [’#e5d4c2’, ‘#c2d4e5’, ‘#d4e5c2’, ‘#e5c2d4’, ‘#d4c2e5’, ‘#e5e1c2’, ‘#c2e5e0’];

var toastTimer;
function toast(msg) {
var old = D.getElementById(‘snr-toast’); if (old) old.remove();
clearTimeout(toastTimer);
var el = D.createElement(‘div’);
el.id = ‘snr-toast’; el.className = ‘snr-toast’;
el.textContent = msg;
D.body.appendChild(el);
toastTimer = setTimeout(function () { el.remove(); }, 2600);
}

function swipe(el) {
el.addEventListener(‘touchstart’, function (e) { S.touchStartX = e.touches[0].clientX; }, { passive: true });
el.addEventListener(‘touchend’, function (e) {
var dx = e.changedTouches[0].clientX - S.touchStartX;
if (Math.abs(dx) > 55) { if (dx < 0) goToPage(S.currentPage + 1); else goToPage(S.currentPage - 1); }
}, { passive: true });
}


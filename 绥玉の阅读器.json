// ─── 发送 ─────────────────────────────────────────────────
async function handleSend() {
var input = D.getElementById(‘snr-input’); if (!input) return;
var msg = input.value.trim(); if (!msg) return;
input.value = ‘’;
S.plusOpen = false; S.thoughtsOpen = false;
S.bubbleLoading = true; S.bubbleText = ‘’;
updateCharArea();
var reply = await generateChat(msg);
S.bubbleLoading = false; S.bubbleText = reply;
updateCharArea();
}

// ─── 局部更新 ─────────────────────────────────────────────
function renderReaderContent() {
var el = D.getElementById(‘snr-content’); if (!el) return;
var lines = curPage().split(’\n’).filter(Boolean);
el.innerHTML = lines.map(function (l) { return ‘<p>’ + esc(l) + ‘</p>’; }).join(’’);
el.scrollTop = 0;
}
function updatePageNav() {
var prev = D.getElementById(‘snr-prev’), next = D.getElementById(‘snr-next’);
if (prev) prev.disabled = S.currentPage === 0;
if (next) next.disabled = S.currentPage >= S.pages.length - 1;
}
function updateTopPageNum() {
var el = D.getElementById(‘snr-page-num’);
if (el) el.textContent = (S.currentPage + 1) + ‘/’ + S.pages.length;
}
function updateBmBtn() {
var el = D.getElementById(‘snr-bm-btn’);
if (el) el.textContent = isBookmarked() ? ‘🔖’ : ‘🏷️’;
}

